# =============================================================
# CAIC Source Discovery — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# =============================================================

# Anthropic Claude API (required for source characterization, report generation, chat)
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# GenSee / search API key (required for web search during pipeline runs)
GENSEE_API_KEY=GENSEE-...

# JWT secret — any long random string, keep it stable or sessions will invalidate
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL connection string
# Leave unset to use the default local DB (postgresql://localhost/caic_sourcing)
DATABASE_URL=postgresql://localhost/caic_sourcing

# Comma-separated list of allowed CORS origins (defaults to * if unset)
# CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# Token expiry in minutes (default: 30)
# ACCESS_TOKEN_EXPIRE_MINUTES=30
